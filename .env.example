# Copy to .env.local and fill in. Never commit .env.local.

# ── Live data (without these, prices/carbon fall back to constants) ──
ANTHROPIC_API_KEY=sk-ant-...
GRIDSTATUS_API_KEY=...                 # https://www.gridstatus.io  (real-time LMP/SPP prices)
ELECTRICITY_MAPS_AUTH_TOKEN=...        # https://www.electricitymaps.com  (carbon + forecast)
OPENWEATHERMAP_API_KEY=...             # https://openweathermap.org

# ── Real actions (optional — the agent still decides without them) ──
# GitHub PAT for the GitOps PR action. Fine-grained, scoped to your repo,
# with Contents: Read & write AND Pull requests: Read & write.
GITHUB_TOKEN=github_pat_...
GITHUB_REPO=owner/repo                 # defaults to saosin06/Gridmind

# Fly.io DEPLOY token (org tokens page — a personal access token is read-only
# and will 403 on machine creation). Value includes a space ("FlyV1 ...").
FLY_API_TOKEN=FlyV1 ...
# FLY_APP=gridmind-jobs                # auto-created on first deploy
# FLY_ORG=personal
